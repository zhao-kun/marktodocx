{
  "name": "markdown-word-converter",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "convert": "node md-to-docx.mjs",
    "build:core": "npm run build -w @marktodocx/core",
    "build:runtime-browser": "npm run build -w @marktodocx/runtime-browser",
    "build:runtime-node": "npm run build -w @marktodocx/runtime-node",
    "build:runtime-node-mermaid": "npm run build -w @marktodocx/runtime-node-mermaid",
    "build:packages": "npm run build:core && npm run build:runtime-browser && npm run build:runtime-node && npm run build:runtime-node-mermaid",
    "build:agent-skill": "npm run build -w marktodocx-agent-skill",
    "export:agent-skill": "npm run export -w marktodocx-agent-skill",
    "export:agent-skill:mermaid": "npm run export -w marktodocx-agent-skill -- --with-mermaid",
    "test:export:agent-skill": "npm run export:agent-skill && node scripts/verify-agent-skill-export.mjs",
    "test:export:agent-skill:mermaid": "npm run export:agent-skill:mermaid && node scripts/verify-agent-skill-export.mjs",
    "build:vscode-extension": "npm run build -w marktodocx-vscode-extension",
    "package:vscode-extension": "npm run package -w marktodocx-vscode-extension",
    "build:cli": "node scripts/build-cli-check.mjs",
    "build:chrome-extension": "npm run build -w marktodocx-chrome-extension",
    "build:extension": "npm run build:chrome-extension",
    "generate:goldens": "npm run build:chrome-extension && node scripts/generate-extension-goldens.mjs",
    "smoke:all": "node scripts/smoke-all-hosts.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test:parity": "npm run build:chrome-extension && npm run test:unit && node scripts/run-fixture-parity.mjs",
    "test:parity:cli": "npm run build:cli && node scripts/run-cli-parity.mjs",
    "test:parity:skill": "npm run build:agent-skill && node scripts/run-agent-skill-parity.mjs",
    "test:parity:vscode": "npm run build:chrome-extension && npm run build:vscode-extension && node scripts/run-vscode-parity.mjs",
    "test:parity:all": "npm run test:parity && npm run test:parity:cli && npm run test:parity:vscode && npm run test:parity:skill"
  },
  "overrides": {
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0"
  },
  "dependencies": {
    "html-to-docx": "^1.8.0",
    "jsdom": "^29.0.2",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "puppeteer": "^23.11.1"
  }
}
