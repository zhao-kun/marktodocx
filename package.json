{
  "name": "markdown-word-converter",
  "private": true,
  "type": "module",
  "scripts": {
    "convert": "node md-to-docx.mjs",
    "build:extension": "npm --prefix markdocx-extension run build",
    "generate:goldens": "npm run build:extension && node scripts/generate-extension-goldens.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test:parity": "npm run build:extension && npm run test:unit && node scripts/run-fixture-parity.mjs"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "dompurify": "^3.3.3",
    "html-to-docx": "^1.8.0",
    "jsdom": "^29.0.2",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "sharp": "^0.34.5",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "puppeteer": "^23.11.1"
  }
}
